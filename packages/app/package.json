{
  "name": "@acme/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "build:preview": "NITRO_PRESET=cloudflare-pages vite build",
    "cf:preview": "pnpm run build:preview && wrangler pages dev --log-level=error dist",
    "cf:db:migrate": "wrangler d1 migrations apply dev --local",
    "cf:db:seed": "wrangler d1 execute dev --local --file=seed.sql",
    "cf:db:reset": "rimraf .wrangler/state && pnpm cf:db:migrate && pnpm cf:db:seed",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "rimraf sqlite.db && pnpm db:migrate && pnpm db:seed",
    "lint": "oxfmt -c ../../.oxfmtrc.json --check . && oxlint -c ../../.oxlintrc.json && tsc -b"
  },
  "dependencies": {
    "@acme/ui": "workspace:*",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@sentry/cloudflare": "catalog:",
    "@sentry/core": "catalog:",
    "@sentry/react": "catalog:",
    "@sentry/vite-plugin": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "drizzle-kit": "catalog:",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wrangler": "catalog:"
  }
}
