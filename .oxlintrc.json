{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["**/routeTree.gen.ts", "**/.turbo/", "**/node_modules/"],
  "env": {
    "node": true,
    "browser": true
  },
  "plugins": ["react", "unicorn", "typescript", "import"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "pedantic": "warn",
    "suspicious": "error",
    "perf": "error",
    "restriction": "error"
  },
  "rules": {
    "eslint/arrow-body-style": "off",
    "eslint/id-length": "error",
    "eslint/no-unused-vars": "off",
    "eslint/no-undef": "off",
    "eslint/no-console": "off",
    "eslint/no-undefined": "off",
    "eslint/no-void": "off",
    "eslint/no-inline-comments": "off",

    // Import
    "eslint-plugin-import/no-default-export": "off",
    "eslint-plugin-import/no-relative-parent-imports": "off",
    "import/no-anonymous-default-export": "error",

    // React
    "eslint-plugin-react/no-multi-comp": ["warn", { "ignoreStateless": true }],
    "eslint-plugin-react/only-export-components": "error",
    "eslint-plugin-react/react-in-jsx-scope": "off",
    "react/only-export-components": "warn",
    "eslint-plugin-react/jsx-filename-extension": [
      "error",
      { "extensions": [".tsx"] }
    ],

    // Typescript
    "typescript/no-deprecated": "error",
    "@typescript-eslint/no-deprecated": "error",
    "@typescript-eslint/array-type": "error",
    "@typescript-eslint/consistent-type-definitions": "error",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "@typescript-eslint/prefer-readonly-parameter-types": "off",
    "@typescript-eslint/consistent-return": "off",
    "typescript/strict-boolean-expressions": "off",
    "@typescript-eslint/promise-function-async": [
      "error",
      { "checkArrowFunctions": false }
    ]
  },
  "options": {
    "maxWarnings": 0,
    "typeAware": true
  },
  "overrides": [
    {
      "files": ["**/routes/**/*.ts", "**/routes/**/*.tsx"],
      "rules": {
        // Route components should be defined after the route itself.
        "eslint/no-use-before-define": "off"
      }
    },
    {
      "files": ["**/*.d.ts"],
      "rules": {
        // Declaration files can export {}
        "unicorn/require-module-specifiers": "off"
      }
    }
  ]
}
