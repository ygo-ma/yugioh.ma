{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/.turbo/",
    "**/node_modules/",
    "**/db/migrations/meta/",
    "**/data/storage/"
  ],
  "printWidth": 80,
  "trailingComma": "none",
  "overrides": [
    { "files": ["**/*.{ts,tsx}"], "options": { "trailingComma": "all" } }
  ]
}
