{
  "name": "@acme/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "oxfmt -c .oxfmtrc.json --check *.* && turbo lint",
    "lint:fix": "oxlint -c .oxlintrc.json --fix && oxfmt -c .oxfmtrc.json",
    "build": "turbo build",
    "test": "turbo test",
    "test:cov": "turbo test:cov",
    "dev": "turbo dev",
    "playwright:install": "playwright install chromium --with-deps",
    "db:generate": "pnpm --filter app db:generate",
    "db:migrate": "pnpm --filter app db:migrate",
    "db:seed": "pnpm --filter app db:seed",
    "db:reset": "pnpm --filter app db:reset",
    "storybook": "pnpm --filter ui storybook",
    "cf:preview": "pnpm --filter app cf:preview",
    "cf:db:migrate": "pnpm --filter app cf:db:migrate",
    "cf:db:seed": "pnpm --filter app cf:db:seed",
    "cf:db:reset": "pnpm --filter app cf:db:reset"
  },
  "devDependencies": {
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
