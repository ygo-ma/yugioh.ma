{
  "name": "@ygoma/workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "oxfmt -c .oxfmtrc.json --check *.* && turbo lint",
    "lint:fix": "oxlint -c .oxlintrc.json --fix && oxfmt -c .oxfmtrc.json",
    "build": "turbo build",
    "test": "turbo test",
    "test:cov": "turbo test:cov",
    "dev": "turbo dev",
    "playwright:install": "playwright install chromium --with-deps",
    "db:generate": "bun run --filter '*/main' db:generate",
    "db:migrate": "bun run --filter '*/main' db:migrate",
    "db:seed": "bun run --filter '*/main' db:seed",
    "db:reset": "bun run --filter '*/main' db:reset",
    "cf:preview": "bun run --filter '*/main' cf:preview",
    "cf:db:migrate": "bun run --filter '*/main' cf:db:migrate",
    "cf:db:seed": "bun run --filter '*/main' cf:db:seed",
    "cf:db:reset": "bun run --filter '*/main' cf:db:reset"
  },
  "devDependencies": {
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "turbo": "catalog:"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "@cloudflare/workers-types": "4.20260317.1",
    "@libsql/client": "0.17.0",
    "@sentry/cloudflare": "10.44.0",
    "@sentry/core": "10.44.0",
    "@sentry/react": "10.44.0",
    "@sentry/vite-plugin": "5.1.1",
    "@storybook/addon-a11y": "10.3.1",
    "@storybook/addon-docs": "10.3.1",
    "@storybook/addon-vitest": "10.3.1",
    "@storybook/react-vite": "10.3.1",
    "@tanstack/react-router": "1.167.4",
    "@tanstack/react-start": "1.166.16",
    "@testing-library/react": "16.3.2",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "bun-types": "1.3.11",
    "classnames": "2.5.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.8",
    "husky": "9.1.7",
    "nitro": "3.0.260311-beta",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.0",
    "playwright": "1.58.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "storybook": "10.3.1",
    "turbo": "2.8.17",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0",
    "wrangler": "4.75.0"
  },
  "trustedDependencies": [
    "@sentry/cli",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
