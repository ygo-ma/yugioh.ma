{
  "name": "@ygoma/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "oxfmt --check *.* && turbo lint",
    "lint:fix": "oxlint -c .oxlintrc.json --fix && oxfmt",
    "build": "turbo build",
    "dev": "turbo dev",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:reset": "pnpm --filter api db:reset",
    "cf:preview": "pnpm --filter web cf:preview",
    "cf:db:migrate": "pnpm --filter web cf:db:migrate",
    "cf:db:seed": "pnpm --filter web cf:db:seed",
    "cf:db:reset": "pnpm --filter web cf:db:reset"
  },
  "devDependencies": {
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
