{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "packages/tsconfig/**/*"
  ],
  "tasks": {
    "lint": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig.json",
        "tsconfig.*.json"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{ts,tsx}",
        "!src/**/*.test.{ts,tsx}",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.*.json"
      ],
      "outputs": [".output/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
