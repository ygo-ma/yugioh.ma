{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["packages/tsconfig/tsconfig.*.json"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{ts,tsx,css}",
        "src/**/migrations/**/*.{json,sql}",
        ".storybook/**",
        "*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/.oxfmtrc.json",
        "$TURBO_ROOT$/.oxlintrc.json"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{ts,tsx,css}",
        ".storybook/**",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json"
      ]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "outputLogs": "new-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{ts,tsx,css}",
        ".storybook/**",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": ["coverage/**/*"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.{ts,tsx,css}",
        "!src/**/*.{test,stories}.{ts,tsx}",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": [".output/**"]
    }
  }
}
