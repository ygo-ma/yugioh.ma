{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["packages/tsconfig/tsconfig.*.json"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "web/**/*.{ts,tsx}",
        "server/**/*.ts",
        "api/**/*.ts",
        "db/**/*.ts",
        "db/migrations/**/*.{json,sql}",
        "*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/.oxfmtrc.json",
        "$TURBO_ROOT$/.oxlintrc.json"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "$TURBO_DEFAULT$",
        "web/**/*.{ts,tsx}",
        "!web/**/*.test.{ts,tsx}",
        "server/**/*.ts",
        "api/**/*.ts",
        "db/**/*.ts",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        ".gitignore",
        "$TURBO_ROOT$/.gitignore",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": [".output/**"]
    }
  }
}
