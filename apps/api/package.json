{
  "name": "@ygoma/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./db/types": "./src/db/types.ts",
    "./db/schema": "./src/db/schema.ts"
  },
  "scripts": {
    "lint": "oxfmt --check && oxlint -c ../../.oxlintrc.json && tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@ygoma/tsconfig": "workspace:*",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
