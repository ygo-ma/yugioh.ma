{
  "name": "@ygoma/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "build:preview": "NITRO_PRESET=cloudflare-pages vite build",
    "cf:preview": "NITRO_PRESET=cloudflare-pages vite build && wrangler pages dev --ip 0.0.0.0 dist",
    "cf:preview:watch": "wrangler pages dev --ip 0.0.0.0 dist",
    "cf:db:migrate": "wrangler d1 migrations apply DB --local",
    "cf:db:seed": "wrangler d1 execute DB --local --file=../api/seed.sql",
    "cf:db:reset": "rm -rf .wrangler/state && wrangler d1 migrations apply DB --local && wrangler d1 execute DB --local --file=../api/seed.sql",
    "start": "node .output/server/index.mjs",
    "lint": "oxfmt --check . && oxlint -c ../../.oxlintrc.json && tsc -b"
  },
  "devDependencies": {
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@ygoma/api": "workspace:*",
    "@ygoma/tsconfig": "workspace:*",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wrangler": "catalog:"
  }
}
